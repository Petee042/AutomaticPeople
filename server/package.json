{
  "name": "automaticpeople",
  "version": "1.0.0",
  "description": "Two-page website with signup and password-protected second page",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "test:auth-validation": "node auth-validation-regression-test.js",
    "test:workflow": "node tests/run-workflows.js",
    "test:workflow:all": "node tests/run-workflows.js --all",
    "test:workflow:precheck-existing-client": "node tests/run-workflows.js --only workflow-00-live-existing-client-precheck",
    "test:workflow:auth": "node tests/run-workflows.js --only workflow-01-auth-smoke",
    "test:workflow:live-onboarding": "node tests/run-workflows.js --only workflow-02-live-onboarding-client-staff-guest",
    "test:workflow:live-onboarding:assist": "node tests/run-workflows.js --only workflow-02-live-onboarding-client-staff-guest --browser-assisted-turnstile",
    "test:workflow:guest-login": "node tests/run-workflows.js --only workflow-03-live-guest-login-from-private-reservation",
    "test:workflow:list": "node tests/run-workflows.js --list"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "csrf": "^3.1.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.17.3",
    "nodemailer": "^9.0.1",
    "pg": "^8.13.1",
    "sanitize-html": "^2.17.4",
    "stripe": "^18.3.0"
  },
  "devDependencies": {
    "puppeteer": "^24.43.1"
  }
}
